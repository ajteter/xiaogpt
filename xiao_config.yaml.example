# This is a YAML configuration file

# ===== Xiaomi =====
# 小米设备型号，可在设备底部标签或米家中确认
hardware: "LX06"
# 设备 DID
mi_did: ""

# 登录方式三选一，推荐优先级：
# 1. passToken
# 2. cookie
# 3. account/password
# 同一时间只保留一种登录方式，其他留空

# --- passToken 登录（推荐）---
mi_user_id: ""
mi_device_id: ""
pass_token: ""

# --- cookie 登录 ---
# 需要包含 deviceId、userId、serviceToken
cookie: ""

# --- 账号密码登录（不稳定，易被风控）---
account: ""
password: ""

# ===== Runtime =====
use_command: false
mute_xiaoai: true
verbose: false
poll_interval: 3
proxy: ""

# ===== Bot =====
bot: "gemini"
prompt: "请用100字以内回答"
keyword:
  - "请"
change_prompt_keyword:
  - "更改提示词"
recall_previous_keyword:
  - "回答上一句"
start_conversation: "开始持续对话"
end_conversation: "结束持续对话"
recall_previous_query_timeout: 90
stream: true
gpt_options: {}

# ===== Gemini =====
gemini_key: ""
# 开启 Google Search 时，推荐明确填写支持搜索的模型
# 例如 gemini-2.0-flash 或你自己已验证可用的更高版本模型
gemini_model: ""
gemini_google_search: false
gemini_api_domain: "https://generativelanguage.googleapis.com"

# ===== Other model keys =====
openai_key: ""
moonshot_api_key: ""
yi_api_key: ""
llama_api_key: ""
serpapi_api_key: ""
glm_key: ""
qwen_key: ""
volc_access_key: ""
volc_secret_key: ""

# ===== TTS =====
tts: "mi"
tts_options: {}
